<Project>
  <PropertyGroup>
    <_RoboticoSharedMsbuildImport Condition="Exists('$(MSBuildThisFileDirectory)Robotico.Library.Shared.props')">$(MSBuildThisFileDirectory)Robotico.Library.Shared.props</_RoboticoSharedMsbuildImport>
    <_RoboticoSharedMsbuildImport Condition="'$(_RoboticoSharedMsbuildImport)' == ''">$([MSBuild]::GetPathOfFileAbove('Robotico.Library.Shared.props', '$(MSBuildThisFileDirectory)'))</_RoboticoSharedMsbuildImport>
  </PropertyGroup>
  <Import Project="$(_RoboticoSharedMsbuildImport)" Condition="'$(_RoboticoSharedMsbuildImport)' != ''" />

  <PropertyGroup>
    <TargetFrameworks>net10.0</TargetFrameworks>
  </PropertyGroup>

  <PropertyGroup>
    <Version>0.1.1</Version>
    <Product>Robotico.Outbox.Mishima</Product>
    <PackageId>Robotico.Outbox.Mishima</PackageId>
    <Title>Robotico.Outbox.Mishima</Title>
    <Description>IOutbox backed by MishimaDocs. Enqueue writes one JSON document per message; optional IMishimaWriteBatch defers persistence until CommitAsync.</Description>
    <PackageTags>outbox;mishima;mishimadocs;robotico</PackageTags>
  </PropertyGroup>

  <PropertyGroup>
    <_RoboticoCsharpNuGetsDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\nugets'))</_RoboticoCsharpNuGetsDir>
  </PropertyGroup>
  <PropertyGroup Condition="Exists('$(_RoboticoCsharpNuGetsDir)')">
    <PackageOutputPath>$([MSBuild]::EnsureTrailingSlash('$(_RoboticoCsharpNuGetsDir)'))</PackageOutputPath>
  </PropertyGroup>

  <!-- MishimaDocs engine: two levels up from this adapter folder → workspace root, then mishima-suite (README layout). -->
  <PropertyGroup>
    <MishimaDocsProjectPath>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\mishima-suite\mishima-docs\src\MishimaDocs\MishimaDocs.csproj'))</MishimaDocsProjectPath>
  </PropertyGroup>
</Project>
